@model IEnumerable<EcommerceMvcApp.Models.Product>

<h2>Available Products</h2>

<table class="table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Price</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.Id</td>
                <td>@p.Name</td>
                <td>@p.Price.ToString("C", new System.Globalization.CultureInfo("en-ZA"))</td>
                <td>
                    <form asp-controller="Store" asp-action="AddToCart" method="post">
                        <input type="hidden" name="prodId" value="@p.Id" />
                        <button type="submit" class="btn btn-primary btn-sm">Add to Cart</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>