@model IEnumerable<EcommerceMvcApp.Models.CartItem>

<h2>Your Cart</h2>

@if (TempData["Message"] != null)
{
    <div class="alert alert-warning">@TempData["Message"]</div>
}

@if (!Model.Any())
{
    <p>Cart is empty.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Product</th>
                <th>Quantity</th>
                <th>Total Price</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Product.Name</td>
                    <td>@item.Quantity</td>
                    <td>@item.TotalPrice.ToString("C", new System.Globalization.CultureInfo("en-ZA"))</td>
                </tr>
            }
        </tbody>
    </table>

    <h4>Total: @Model.Sum(c => c.TotalPrice).ToString("C", new System.Globalization.CultureInfo("en-ZA"))</h4>

    <form asp-controller="Store" asp-action="Checkout" method="post">
        <button type="submit" class="btn btn-success mt-3">Checkout</button>
    </form>
}