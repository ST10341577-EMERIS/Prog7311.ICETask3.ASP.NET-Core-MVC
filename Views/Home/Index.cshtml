@{
    ViewData["Title"] = "Home Page";
}

<div class="hero-section text-center">
    <h1 class="display-4 fw-bold mb-3">Welcome to TechStore</h1>
    <p class="lead text-muted mb-4">Your one-stop destination for the latest laptops, phones, and tablets.</p>
    
    <a asp-controller="Store" asp-action="Index" class="btn btn-primary btn-lg shadow-sm px-5 py-3 custom-btn">
        Start Shopping
    </a>
</div>

<div class="row mt-5 features-section text-center">
    <div class="col-md-4 mb-4">
        <div class="feature-box p-4 shadow-sm rounded">
            <h4 class="fw-bold">🚀 Fast Delivery</h4>
            <p class="text-muted">Get your new tech delivered to your door within 24 hours.</p>
        </div>
    </div>
    <div class="col-md-4 mb-4">
        <div class="feature-box p-4 shadow-sm rounded">
            <h4 class="fw-bold">🔒 Secure Checkout</h4>
            <p class="text-muted">Your payments are 100% safe, encrypted, and protected.</p>
        </div>
    </div>
    <div class="col-md-4 mb-4">
        <div class="feature-box p-4 shadow-sm rounded">
            <h4 class="fw-bold">💻 Premium Gear</h4>
            <p class="text-muted">We only stock the highest quality brands and devices.</p>
        </div>
    </div>
</div>